{
  "manifest_version": 3,
  "name": "OneClickFiller",
  "version": "1.0.0",
  "description": "Fill your college feedback form in one click. Made by students of Amity University.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}